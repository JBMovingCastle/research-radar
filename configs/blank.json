    "openalex": {"enabled": false, "api_key_env": "OPENALEX_API_KEY"},
    "feeds": [],
    "web_pages": []
  },
  "delivery": {"default": "local", "feishu": {"user_id_env": "FEISHU_USER_ID", "command": "lark-cli"}},
  "paths": {"briefs_dir": "10-daily-briefs", "topics_dir": "20-topics", "runs_dir": "90-system/runs", "ledger_file": "90-system/index/recommendation-ledger.jsonl"},
