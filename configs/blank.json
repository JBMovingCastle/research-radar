      "selection_heading": "今日入选",
      "analysis_heading": "首篇分析边界"
    }
  },
  "score_weights": {"relevance": 40, "source_quality": 25, "recency": 15, "impact": 10, "novelty": 10},
  "context_keywords": ["artificial intelligence"],
  "exclusion_keywords": ["sponsored", "advertorial"],
  "tracks": [
    {"id": "main", "name": "主要研究方向", "keywords": ["artificial intelligence"], "queries": ["artificial intelligence research"]}
  ],
  "rotation": {"monday": "main", "tuesday": "main", "wednesday": "main", "thursday": "main", "friday": "main", "saturday": "main", "sunday": "main"},
