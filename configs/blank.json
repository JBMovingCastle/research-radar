    "item_fields": ["evidence", "authors", "published_date", "venue", "matched_track", "score", "sources", "doi", "url", "abstract"],
    "abstract_limit": 900,
    "style": {
      "intro": "面向研究团队的简洁日报：先说明来源覆盖，再呈现可追溯的入选内容。",
